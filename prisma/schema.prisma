// prisma/schema.prisma



// HOW TO USE
// npx prisma db push : update structure of database
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Order {
  id        String   @id @default(uuid())
  buyerName String
  item      String
  quantity  Int
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
}